        local active = StealState.active
        local justFinished = StealState.lastResultTime > 0 and (tick() - StealState.lastResultTime) < 1.15
        local success = justFinished and string.find(StealState.lastResult, "Stole") ~= nil

        local targetPct = 0
        if active then
            targetPct = math.clamp((tick() - StealState.startTime) / CONFIG.HOLD_MAX, 0, 1)
        elseif justFinished then
            targetPct = success and 1 or 0.35
        else
            targetPct = 0
        end

        lastFillPct = lastFillPct + (targetPct - lastFillPct) * math.min(dt * 14, 1)
        fill.Size = UDim2.new(lastFillPct, 0, 1, 0)

        local shownPct = math.floor(math.clamp(lastFillPct, 0, 1) * 100 + 0.5)

        if not on then
            title.Text = "ACE DUELS  |  OFF"
            title.TextTransparency = 0.28
            fill.BackgroundTransparency = 1
            barStroke.Transparency = 0.48
        else
            title.Text = "ACE DUELS  |  " .. tostring(shownPct) .. "%"
            title.TextTransparency = 0
            fill.BackgroundTransparency = active and 0.62 or 0.82
            barStroke.Transparency = active and 0.04 or 0.18
        end

        if active then
            barStroke.Color = THEME.white
        elseif justFinished and success then
            barStroke.Color = THEME.white
        else
            barStroke.Color = THEME.stroke
        end
    end)
end

