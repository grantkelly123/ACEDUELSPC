local CONFIG_FILE = "AceDuelsAutoStealTopBarConfig.json"
local _ace_isfile = isfile or (syn and syn.isfile) or function(path)
    local ok, result = pcall(function()
        return readfile(path)
    end)
    return ok and result ~= nil
end
local _ace_readfile = readfile or (syn and syn.readfile)
local _ace_writefile = writefile or (syn and syn.writefile)
local canSaveConfig = type(_ace_readfile) == "function" and type(_ace_writefile) == "function"

local function saveAceStealConfig()
    if not canSaveConfig then return end
    pcall(function()
        _ace_writefile(CONFIG_FILE, S.HttpService:JSONEncode({
            AUTO_STEAL_ENABLED = CONFIG.AUTO_STEAL_ENABLED == true,
            STEAL_RANGE = tonumber(CONFIG.STEAL_RANGE) or 9,
        }))
    end)
end

local function loadAceStealConfig()
    if not canSaveConfig or not _ace_isfile(CONFIG_FILE) then return end
    local ok, data = pcall(function()
        return S.HttpService:JSONDecode(_ace_readfile(CONFIG_FILE))
    end)
    if not ok or type(data) ~= "table" then return end
    if data.AUTO_STEAL_ENABLED ~= nil then
        CONFIG.AUTO_STEAL_ENABLED = data.AUTO_STEAL_ENABLED == true
    end
    if data.STEAL_RANGE ~= nil then
        CONFIG.STEAL_RANGE = math.clamp(math.floor(tonumber(data.STEAL_RANGE) or 9), 1, 500)
    end
end

