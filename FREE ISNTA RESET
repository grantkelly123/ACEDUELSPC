--// Ace Duels Insta Reset Logic
_G.AceDuelsResetRemote = _G.AceDuelsResetRemote or nil
_G.AceDuelsResetGuid = _G.AceDuelsResetGuid or "f888ee6e-c86d-46e1-93d7-0639d6635d42"

pcall(function()
	if not _G.AceDuelsResetHooked and hookfunction and newcclosure then
		_G.AceDuelsResetHooked = true

		local oldFire
		oldFire = hookfunction(Instance.new("RemoteEvent").FireServer, newcclosure(function(self, ...)
			if not _G.AceDuelsResetRemote
				and typeof(self) == "Instance"
				and self:IsA("RemoteEvent")
				and self.Name:sub(1, 3) == "RE/" then
				_G.AceDuelsResetRemote = self
			end

			return oldFire(self, ...)
		end))
	end
end)

local function findAceDuelsResetRemote()
	if _G.AceDuelsResetRemote then
		return _G.AceDuelsResetRemote
	end

	for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
		if desc:IsA("RemoteEvent") and desc.Name:sub(1, 3) == "RE/" then
			_G.AceDuelsResetRemote = desc
			break
		end
	end

	return _G.AceDuelsResetRemote
end

local function aceDuelsInstaReset()
	local remote = findAceDuelsResetRemote()
	if not remote then
		return false
	end

	local character = player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")

	if humanoid and humanoid.Health <= 0 then
		pcall(function()
			remote:FireServer(_G.AceDuelsResetGuid, player, "balloon")
		end)
		return true
	end

	local resetDetected = false
	local resetConns = {}

	if humanoid then
		table.insert(resetConns, humanoid.Died:Connect(function()
			resetDetected = true
		end))

		table.insert(resetConns, humanoid:GetPropertyChangedSignal("Health"):Connect(function()
			if humanoid.Health <= 0 then
				resetDetected = true
			end
		end))
	end

	if character then
		table.insert(resetConns, character.AncestryChanged:Connect(function(_, parent)
			if not parent then
				resetDetected = true
			end
		end))
	end

	task.spawn(function()
		for _ = 1, 10 do
			if resetDetected then
				break
			end

			pcall(function()
				remote:FireServer(_G.AceDuelsResetGuid, player, "balloon")
			end)

			task.wait(0.05)
		end

		for _, conn in ipairs(resetConns) do
			pcall(function()
				conn:Disconnect()
			end)
		end
	end)

	return true
end

_G.AceDuelsInstaReset = aceDuelsInstaReset


--// Auto Reset On Med Fling Logic
_G.AceDuelsAutoResetOnMedFling = _G.AceDuelsAutoResetOnMedFling or {
	conns = {},
	enabled = savedConfig.autoResetOnMedFling == true,
	medTriggered = false,
	lastFire = 0,
	cooldown = 2.25,
	charAddedConn = nil
}

local function stopAutoResetOnMedFling()
	local state = _G.AceDuelsAutoResetOnMedFling
	for _, conn in ipairs(state.conns or {}) do
		pcall(function()
			conn:Disconnect()
		end)
	end
	state.conns = {}
	state.medTriggered = false
end

local function shouldAutoResetOnMedFling(part)
	local state = _G.AceDuelsAutoResetOnMedFling
	if not state or not state.enabled then return false end
	if state.medTriggered then return false end
	if tick() - (state.lastFire or 0) < (state.cooldown or 2.25) then return false end
	if not part or not part.Parent then return false end
	if part:FindFirstAncestorOfClass("Tool") or part:FindFirstAncestorOfClass("Accessory") then return false end
	return part.Anchored == true and part.Transparency == 1
end

local function fireAutoResetOnMedFling(part)
	if not shouldAutoResetOnMedFling(part) then return end
	local state = _G.AceDuelsAutoResetOnMedFling
	state.medTriggered = true
	state.lastFire = tick()

	task.delay(2.3, function()
		if state.enabled then
			aceDuelsInstaReset()
		end
	end)
end

local function startAutoResetOnMedFling(char)
	local state = _G.AceDuelsAutoResetOnMedFling
	stopAutoResetOnMedFling()
	state.medTriggered = false
	char = char or player.Character
	if not char then return end

	for _, part in ipairs(char:GetDescendants()) do
		if part:IsA("BasePart") then
			table.insert(state.conns, part:GetPropertyChangedSignal("Anchored"):Connect(function()
				fireAutoResetOnMedFling(part)
			end))
			fireAutoResetOnMedFling(part)
		end
	end

	table.insert(state.conns, char.DescendantAdded:Connect(function(part)
		if part:IsA("BasePart") then
			table.insert(state.conns, part:GetPropertyChangedSignal("Anchored"):Connect(function()
				fireAutoResetOnMedFling(part)
			end))
			fireAutoResetOnMedFling(part)
		end
	end))

	table.insert(state.conns, char.AncestryChanged:Connect(function(_, parent)
		if not parent then
			state.medTriggered = false
		end
	end))
end

local setAutoMedVisual
local function setAutoResetOnMedFling(on)
	local state = _G.AceDuelsAutoResetOnMedFling
	state.enabled = on == true
	savedConfig.autoResetOnMedFling = state.enabled

	if state.enabled then
		startAutoResetOnMedFling(player.Character)
	else
		stopAutoResetOnMedFling()
	end

	if setAutoMedVisual then
		setAutoMedVisual(state.enabled)
	end

	saveAceConfig()
end

if not _G.AceDuelsAutoResetOnMedFling.charAddedConn then
	_G.AceDuelsAutoResetOnMedFling.charAddedConn = player.CharacterAdded:Connect(function(char)
		task.wait(0.25)
		if _G.AceDuelsAutoResetOnMedFling.enabled then
			startAutoResetOnMedFling(char)
		end
	end)
end

