--// Save Config
local CONFIG_FILE = "AceDuelsInstaReset_Config.json"

local _ace_isfile = isfile or (syn and syn.isfile) or function(path)
	local ok, result = pcall(function()
		return readfile(path)
	end)
	return ok and result ~= nil
end

local _ace_readfile = readfile or (syn and syn.readfile)
local _ace_writefile = writefile or (syn and syn.writefile)

local canSaveConfig = type(_ace_readfile) == "function" and type(_ace_writefile) == "function"

local savedConfig = {}

local function udim2ToTable(u)
	return {
		xs = u.X.Scale,
		xo = u.X.Offset,
		ys = u.Y.Scale,
		yo = u.Y.Offset
	}
end

local function tableToUDim2(t, fallback)
	if type(t) == "table" then
		return UDim2.new(
			tonumber(t.xs) or fallback.X.Scale,
			tonumber(t.xo) or fallback.X.Offset,
			tonumber(t.ys) or fallback.Y.Scale,
			tonumber(t.yo) or fallback.Y.Offset
		)
	end

	return fallback
end

local function loadAceConfig()
	if not canSaveConfig then return end
	if not _ace_isfile(CONFIG_FILE) then return end

	local ok, data = pcall(function()
		return HttpService:JSONDecode(_ace_readfile(CONFIG_FILE))
	end)

	if ok and type(data) == "table" then
		savedConfig = data
	end
end

local function saveAceConfig()
	if not canSaveConfig then return end

	pcall(function()
		_ace_writefile(CONFIG_FILE, HttpService:JSONEncode(savedConfig))
	end)
end

loadAceConfig()

