local function keyToString(key)
    return key and tostring(key):gsub("Enum.KeyCode.", "") or "None"
end

local function stringToKeyCode(value)
    if type(value) ~= "string" or value == "" or value == "None" then return nil end
    return Enum.KeyCode[value]
end

local canSave = type(writefile) == "function" and type(readfile) == "function"
local function saveConfig()
    if not canSave then return end
    local cfg = {
        autoBatKey = keyToString(Keys.autoBat),
        autoBatKeyType = Keys.autoBatType,
        mobileMode = State.mobileMode,
        autoSwingToggledOn = State.autoSwingToggledOn,
    }
    pcall(function()
        writefile(CONFIG_FILE, HttpService:JSONEncode(cfg))
    end)
end

local function loadConfig()
    if not canSave then return end
    local hasFile = false
    pcall(function() hasFile = isfile and isfile(CONFIG_FILE) end)
    if not hasFile then return end
    local ok, cfg = pcall(function()
        return HttpService:JSONDecode(readfile(CONFIG_FILE))
    end)
    if not ok or type(cfg) ~= "table" then return end
    if cfg.autoBatKey then Keys.autoBat = stringToKeyCode(cfg.autoBatKey) or Keys.autoBat end
    if cfg.autoBatKeyType then Keys.autoBatType = cfg.autoBatKeyType end
    if cfg.mobileMode ~= nil then State.mobileMode = cfg.mobileMode == true end
    if cfg.autoSwingToggledOn ~= nil then State.autoSwingToggledOn = cfg.autoSwingToggledOn == true end
end
